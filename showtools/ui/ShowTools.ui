  <property name="styleSheet">
   <string notr="true">/* ============================= */
/* GLOBAL TEXT */
/* ============================= */

QWidget {
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
}


/* ============================= */
/* MAIN APP SURFACES */
/* ============================= */

/* Root widget background */
QWidget#wgShowTools {
    background-color: #3a3a3a;
}

/* Stacked widget / pages = lower section background */
QStackedWidget,
QStackedWidget &gt; QWidget {
    background-color: #3a3a3a;
}

/* Lower section strip */
QFrame#lower_edge {
    background-color: #2f2f2f;
}


/* ============================= */
/* HEADER */
/* ============================= */

#headerFrame {
    background-color: #090909;
    border: none;
}

QLabel#label_showTools {
    font-weight: 600;
    font-size: 40pt;
    color: #ededed;
    background: transparent;
}

QLabel#label_version {
    font-size: 10pt;
    color: #bdbdbd;
    background: transparent;
}


/* ============================= */
/* CARD PANELS */
/* ============================= */

/* Instructions card = black */
QFrame#frame01_instructions {
    background-color: #090909;
    border-radius: 3px;
    border: none;
}

QLabel#label_resources {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 600;
    background: transparent;
}

/* Main cards = darker grey than page background */
QFrame#frame_pipelineProfile,
QFrame#frame_projectDetails,
QFrame#frame_packageSettings {
    background-color: #2f2f2f;
    border: 1px solid #3a3a3a;
    border-radius: 3px;
}


QFrame#frame_targetFolder {
    background: transparent;
    border: none;
    border-bottom: 1px solid #3a3a3a;
}

/* Right column holder transparent */
QWidget#widget_columnRight {
    background: transparent;
}


/* ============================= */
/* CARD TITLES */
/* ============================= */

QLabel#title_pipelineProfile,
QLabel#title_projectDetails,
QLabel#title_packageSettings {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

QLabel#title_targetFolder {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}

QFrame#targetFolderDivider {
    background-color: #5a5a5a;   /* softer than white */
    max-height: 2px;
    min-height: 2px;
    border: none;
}

QLabel#label_instructionsTitle {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 15pt;
    font-weight: 700;
    background: transparent;
}


/* ============================= */
/* MAIN FORM LABELS */
/* ============================= */

/* Project details body labels */
QLabel#label_projectName,
QLabel#label_shootDate,
QLabel#label_wrangler,
QLabel#label_unit {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}

/* Package settings body labels */
QLabel#label_prefix,
QLabel#label_suffix,
QLabel#label_remove,
QLabel#label_renamePackage,
QLabel#label_generateYAML,
QLabel#label_notifyByEmail,
QLabel#label_makeReverseManifest {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}


/* ============================= */
/* INSTRUCTIONS PANEL */
/* ============================= */

QTextBrowser {
    background: transparent;
    border: none;
    color: #ededed;
    font-size: 9.5pt;
}

QScrollBar:vertical {
    background: #2f2f2f;
    width: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #6a6a6a;
    min-height: 20px;
    border-radius: 2px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}


/* ============================= */
/* INPUT FIELDS */
/* ============================= */

QLineEdit,
QComboBox,
QDateEdit {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-radius: 2px;
    padding: 0px 6px;
}

QLineEdit:focus,
QComboBox:focus,
QDateEdit:focus {
    border: 1px solid #f0b000;
}

QComboBox::down-arrow {
    image: url(:/icons/icons/down.png);
    width: 10px;
    height: 10px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #b8b8b8;
    background-color: #cfcfcf;
}


/* ============================= */
/* CHECKBOXES */
/* ============================= */

QCheckBox {
    spacing: 6px;
    background: transparent;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
}

QCheckBox::indicator:unchecked {
    background: #dcdcdc;
    border: 1px solid #9a9a9a;
}

QCheckBox::indicator:checked {
    background: #f0b000;
    border: 1px solid #f0b000;
}


/* ============================= */
/* DIVIDER LINES */
/* ============================= */

QFrame[frameShape=&quot;4&quot;] {
    color: #6b6b6b;
}


/* ============================= */
/* BUTTONS */
/* ============================= */

/* Make all main buttons yellow */
QPushButton,
QPushButton#btn_saveSettings,
QPushButton#btn_clearSettings,
QPushButton#btn_export {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-radius: 3px;
    padding: 4px 10px;
    font-weight: 600;
}

QPushButton:hover,
QPushButton#btn_saveSettings:hover,
QPushButton#btn_clearSettings:hover,
QPushButton#btn_export:hover {
    background-color: #ffc533;
}

QPushButton:pressed,
QPushButton#btn_saveSettings:pressed,
QPushButton#btn_clearSettings:pressed,
QPushButton#btn_export:pressed {
    background-color: #d89c00;
}

/* Top tabs */
QPushButton#btn_mainSettings,
QPushButton#btn_renameSettings {
    background: transparent;
    border: none;
    font-weight: 600;
    font-size: 11pt;
    color: #ededed;
}

QPushButton#btn_mainSettings:checked,
QPushButton#btn_renameSettings:checked {
    color: #f0b000;
}

/* Browse icon buttons */
QPushButton#btn_browseConfig {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-radius: 2px;
    padding: 0px;
    min-width: 28px;
    max-width: 28px;
    min-height: 28px;
    max-height: 28px;
}

QPushButton#btn_browseTargetFolder {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-left: 1px solid #b8b8b8;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
    padding: 0px;
    min-width: 21px;
    max-width: 21px;
    min-height: 21px;
    max-height: 21px;
}

QPushButton#btn_browseConfig:hover,
QPushButton#btn_browseTargetFolder:hover {
    background-color: #ffc533;
}

QPushButton#btn_browseConfig:pressed,
QPushButton#btn_browseTargetFolder:pressed {
    background-color: #d89c00;
}

/* Instruction icon buttons */
QPushButton#btn_youtube,
QPushButton#btn_website,
QPushButton#btn_gmail,
QPushButton#btn_github,
QPushButton#btn_linkedin {
    background: transparent;
    border: none;
    padding: 4px;
}

QPushButton#btn_youtube:hover,
QPushButton#btn_website:hover,
QPushButton#btn_gmail:hover,
QPushButton#btn_github:hover,
QPushButton#btn_linkedin:hover {
    background-color: #2f2f2f;
    border-radius: 3px;
}


/* ============================= */
/* COMBO BOXES */
/* ============================= */

QComboBox {
    background-color: #dcdcdc;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-radius: 2px;
    padding: 1px 6px;
    min-height: 24px;
}

QComboBox:focus {
    border: 1px solid #f0b000;
}

/* Right-side drop area */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #bcbcbc;
    background-color: #d0d0d0;
}

/* Visible arrow */
QComboBox::down-arrow {
    width: 10px;
    height: 10px;
}

/* Popup list */
QComboBox QAbstractItemView {
    background-color: #2f2f2f;
    color: #ededed;
    border: 1px solid #4a4a4a;
    selection-background-color: #f0b000;
    selection-color: #1b1b1b;
    outline: none;
}


/* ============================= */
/* DATE EDIT */
/* ============================= */

QDateEdit {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #b8b8b8;
    border-radius: 2px;
    padding: 1px 6px;
    min-height: 24px;
}

QDateEdit:focus {
    border: 1px solid #f0b000;
}

QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #b8b8b8;
    background-color: #cccccc;
}

QDateEdit::down-arrow {
    image: url(:/icons/icons/calendar.png);
    width: 12px;
    height: 12px;
}


/* ============================= */
/* CALENDAR POPUP */
/* ============================= */

QCalendarWidget QWidget {
    background-color: #2f2f2f;
    color: #ededed;
}

QCalendarWidget QToolButton {
    background-color: #2f2f2f;
    color: #f0b000;
    border: none;
    font-weight: 600;
}

QCalendarWidget QToolButton:hover {
    background-color: #3a3a3a;
}

QCalendarWidget QMenu {
    background-color: #2f2f2f;
    color: #ededed;
    border: 1px solid #4a4a4a;
}

QCalendarWidget QSpinBox {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #b8b8b8;
    border-radius: 2px;
}

QCalendarWidget QAbstractItemView:enabled {
    background-color: #2f2f2f;
    color: #ededed;
    selection-background-color: #f0b000;
    selection-color: #1b1b1b;
    outline: none;
}

QCalendarWidget QAbstractItemView:disabled {
    color: #777777;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #2f2f2f;
    border-bottom: 1px solid #3a3a3a;
}

QCalendarWidget QToolButton {
    padding-right: 12px;
}

QLineEdit#input_targetFolder {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-right: none;
    border-top-left-radius: 2px;
    border-bottom-left-radius: 2px;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 0px;
    padding: 0px 6px;
}

QLineEdit#input_targetFolder[pathState=&quot;missing&quot;] {
    border: 2px solid #d96c6c;
}

QLineEdit#input_targetFolder[pathState=&quot;valid&quot;] {
    border: 2px solid #5fcf8f;
}

QLineEdit:disabled {
    background-color: #5a5a5a;
    color: #9a9a9a;
    border: 1px solid #4a4a4a;
}

QComboBox:disabled,
QDateEdit:disabled {
    background-color: #5a5a5a;
    color: #9a9a9a;
    border: 1px solid #4a4a4a;
}

QLabel#label_remove:disabled,
QLabel#label_prefix:disabled,
QLabel#label_suffix:disabled {
    color: #7a7a7a;
}

/* ============================= */
/* RENAME SETTINGS PAGE */
/* ============================= */

/* ---------- ADD RULE ---------- */

QPushButton#btn_addRule {
    background-color: transparent;
    color: #d0d0d0;
    border: none;
    padding: 10px 10px 6px 10px;
    margin-top: 8px;
    font-weight: 600;
}

QPushButton#btn_addRule:hover {
    background-color: #2a2a2a;
    color: #ffffff;
}

QPushButton#btn_addRule:pressed {
    background-color: #1c1c1c;
    color: #f0b000;
}

/* Empty state: Add Rule is the only item, so make it look like a primary convention row */
QPushButton#btn_addRule[emptyState=&quot;true&quot;] {
    background-color: transparent;
    color: #f0b000;
    border: none;
    padding: 10px 10px 6px 10px;
    margin-top: 8px;
    font-weight: 600;
}

QPushButton#btn_addRule[emptyState=&quot;true&quot;]:hover {
    background-color: #2a2a2a;
    color: #ffc533;
}

QPushButton#btn_addRule[emptyState=&quot;true&quot;]:pressed {
    background-color: #1c1c1c;
    color: #d89c00;
}

/* ---------- DELETE RULE ---------- */

QPushButton#btn_ruleDelete {
    background: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
    min-width: 18px;
    max-width: 18px;
    min-height: 18px;
    max-height: 18px;
}

QPushButton#btn_ruleDelete:hover {
    background: transparent;
    border: none;
}

QPushButton#btn_ruleDelete:pressed {
    background: transparent;
    border: none;
}

QLabel#label_ruleItem {
    background: transparent;
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 600;
}

QLabel#label_ruleItem[selectedRule=&quot;true&quot;] {
    color: #f0b000;
}

/* ---------- TOKEN PILLS ---------- */

QPushButton[tokenButton=&quot;true&quot;] {
    background-color: #f0b000;
    color: #111111;
    border: none;
    border-radius: 1px;

    min-height: 22px;
    max-height: 22px;

    min-width: 70px;
    max-width: 70px;

    padding: 0px 8px;
    font-weight: 600;
    font-size: 9pt;
}

/* ---------- RESET BUTTON ---------- */

QPushButton#btn_clearNamingRule {
    background-color: #f0b000;
    color: #111111;

    border: 2px solid #bdbdbd;
    border-radius: 2px;

    min-height: 26px;
    max-height: 26px;

    min-width: 64px;
    max-width: 64px;

    padding: 0px 10px;
    font-weight: 600;
}

QPushButton[tokenButton=&quot;true&quot;]:hover,
QPushButton#btn_clearNamingRule:hover {
    background-color: #e0b84a;
}

QPushButton[tokenButton=&quot;true&quot;]:pressed,
QPushButton#btn_clearNamingRule:pressed {
    background-color: #a8842c;
}

/* ---------- TOP STRIP HEADERS ---------- */

QFrame#frame_rulesHeader,
QFrame#frame_editorHeader,
QFrame#frame_previewHeader,
QFrame#divider_upper {
    background-color: #181818;
    border: none;
}

/* ---------- PANEL DIVIDERS ---------- */

QFrame#divider_lower,
QFrame#frame_divider {
    background-color: #5a5a5a;
    border: none;
}

/* ---------- MAIN PANEL BACKGROUNDS ---------- */

/* Rules + Preview side panels */
QFrame#frame_previewBody {
    background-color: #3a3a3a;
    border: none;
    outline: none;
}

QWidget#frame_rulesPanel {
    background-color: #2f2f2f;
    border: none;
    outline: none;
}

/* Editor background area */
QWidget#frame_editorPanel,
QFrame#frame_editorBody,
QFrame#vertical_layout_rule_editor,
QFrame#frame_body {
    background-color: #3a3a3a;
    border: none;
    outline: none;
}

/* ---------- MAIN CARDS ---------- */

QFrame#frame_sortingDetails {
    background-color: #262626;
    border: none;
    border-radius: 0px;
}

QFrame#frame_renameDetails {
    background-color: #262626;
    border: none;
    border-radius: 0px;
}

/* ---------- INNER RENAME PANELS ---------- */

QFrame#frame_tokenPanel,
QFrame#example_panel {
    background-color: #090909;
    border: none;
    border-radius: 0px;
}

QFrame#frame_nameTokens,
QFrame#frame_metadataTokens {
    background: transparent;
    border: none;
}

/* remove unwanted frames */
QFrame#name_token_frame,
QFrame#metadata_token_frame,
QFrame#frame_input_naming_rule,
QFrame#frame_rulesBody,
QFrame#frame_inputDetails,
QFrame#frame_input_renameDetails {
    background: transparent;
    border: none;
    outline: none;
}

/* ---------- TITLES ---------- */

QLabel#title_sortingDetails,
QLabel#title_renameDetails {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

QLabel#title_namingRule {
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

/* ---------- CHECK IF DATA TYPE PRESENT ---------- */

QLineEdit#input_dataTypeRename[dataTypeState=&quot;valid&quot;] {
    border: 2px solid #5fcf8f;
}

QLineEdit#input_dataTypeRename[dataTypeState=&quot;missing&quot;] {
    border: 2px solid #d96c6c;
}

QLineEdit#input_dataTypeRename[dataTypeState=&quot;neutral&quot;] {
    border: 2px solid #bcbcbc;
}

/* ---------- RULES LIST ---------- */

QListWidget#list_rules,
QListWidget#list_rules QAbstractItemView {
    background-color: #2f2f2f;
    color: #ededed;
    border: none;
    outline: none;

    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 600;
}

QListWidget#list_rules::item {
    border-bottom: 1px solid #5a5a5a;
    padding: 0px;
    margin: 0px;
}

QListWidget#list_rules::item {
    border-bottom: 1px solid #5a5a5a;
    padding: 0px;
    margin: 0px;
}

QListWidget#list_rules::item:hover {
    background-color: #222222;
}

QListWidget#list_rules::item:selected {
    color: #f0b000;
    background: transparent;
}

/* ---------- SORTING DETAILS LABELS ---------- */

QFrame#frame_inputDetails QLabel,
QFrame#frame_inputDetails QCheckBox {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
    background: transparent;
}



QFrame#frame_sortingDetails QCheckBox {
    spacing: 40px;
}

/* ---------- SMALL HEADERS IN TOKEN PANEL ---------- */

QLabel[isHeader=&quot;true&quot;] {
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}


/* ---------- EXAMPLE TEXT ---------- */

QLabel#label_exampleRule {
    color: #ffffff;
    font-size: 11pt;
    font-style: italic;
    font-weight: bold;
    background: transparent;
}

/* ---------- PREVIEW TREE ---------- */

QTreeView#tree_preview {
    background-color: #2f2f2f;
    color: #e6e6e6;
    border: none;
    outline: none;
    padding: 4px;
}

QTreeView#tree_preview::item {
    height: 24px;
    padding: 4px 8px;
    border: none;
}

QTreeView#tree_preview::item:hover {
    background-color: #3a3a3a;
}

QTreeView#tree_preview::item:selected {
    background-color: #f0b000;
    color: #1b1b1b;
}

QTreeView#tree_preview::branch {
    background: transparent;
}

/* Header */
QFrame#frame_previewTreeHeader {
    background-color: #2a2a2a;
    border-bottom: 1px solid #4a4a4a;
    padding: 6px 0px;
}

QLabel#label_previewTreeHeader {
    color: #d8a106;
    font-size: 10.5pt;
    font-weight: 600;
    letter-spacing: 0.5px;
}

/* ---------- EMPTY EDITOR ---------- */

QFrame#frame_editorEmptyCard,
QFrame#frame_previewEmptyCard {
    background-color: #2a2a2a;
    border: 1px solid #3a3a3a;
    border-radius: 4px;
    padding: 20px;
}

QLabel#label_editorEmptyTitle,
QLabel#label_previewEmptyTitle {
    color: #d8a106;
    font-size: 13pt;
    font-weight: 600;
    background: transparent;
}

QLabel#label_editorEmptyDetail,
QLabel#label_previewEmptyDetail{
    color: #8a8a8a;
    font-size: 10pt;
    background: transparent;
}

/* ---------- CENTERING INPUT FIELD TEXT ---------- */

QLineEdit#input_dataTypeRename {
    qproperty-alignment: AlignCenter;
    padding-left: 0px;
    padding-right: 0px;
}

/* ---------- NAMING RULE INPUT FIELD ---------- */

QLineEdit#input_namingRule {
    background-color: #d7d7d7;
    color: #1b1b1b;
    border: 2px solid #bdbdbd;
    border-radius: 2px;
    padding: 0px 10px;
    min-height: 26px;
    max-height: 26px;
    font-size: 11pt;
}

QLineEdit#input_namingRule:focus {
    border: 2px solid #f0b000;
}

/* ----------PREVIEW SCROLLBAR: HORIZONTAL ---------- */

QTreeView#tree_preview QScrollBar:horizontal {
    background: #1f1f1f;
    min-height: 14px;
    max-height: 14px;
    margin: 0px;
    border-top: 1px solid #4a4a4a;
}

QTreeView#tree_preview QScrollBar::handle:horizontal {
    background: #9a9a9a;
    min-width: 36px;
    border-radius: 2px;
}

QTreeView#tree_preview QScrollBar::handle:horizontal:hover {
    background: #c0c0c0;
}

QTreeView#tree_preview QScrollBar::handle:horizontal:pressed {
    background: #d8a106;
}

QTreeView#tree_preview QScrollBar::add-line:horizontal,
QTreeView#tree_preview QScrollBar::sub-line:horizontal {
    width: 0px;
}

QTreeView#tree_preview QScrollBar::add-page:horizontal,
QTreeView#tree_preview QScrollBar::sub-page:horizontal {
    background: #2f2f2f;
}

/* ----------PREVIEW SCROLLBAR: VERTICAL ---------- */

QTreeView#tree_preview QScrollBar:vertical {
    background: #222222;
    width: 14px;
    margin: 0px;
    border-left: 1px solid #4a4a4a;
}

QTreeView#tree_preview QScrollBar::handle:vertical {
    background: #8a8a8a;
    min-height: 28px;
    border-radius: 2px;
}

QTreeView#tree_preview QScrollBar::handle:vertical:hover {
    background: #aaaaaa;
}

QTreeView#tree_preview QScrollBar::handle:vertical:pressed {
    background: #c0c0c0;
}

QTreeView#tree_preview QScrollBar::add-line:vertical,
QTreeView#tree_preview QScrollBar::sub-line:vertical {
    height: 0px;
}

QTreeView#tree_preview QScrollBar::add-page:vertical,
QTreeView#tree_preview QScrollBar::sub-page:vertical {
    background: #2f2f2f;
}

/* ----------REVERT SORT BUTTON ---------- */

QPushButton#btn_revert[revertState=&quot;disabled&quot;] {
	background-color: #4a4a4a;
	color: #7a7a7a;
}

QPushButton#btn_revert[revertState=&quot;disabled&quot;]:hover {
	background-color: #4a4a4a;
	color: #7a7a7a;
}

QPushButton#btn_revert[revertState=&quot;disabled&quot;]:pressed {
	background-color: #4a4a4a;
	color: #7a7a7a;
}

QPushButton#btn_revert[revertState=&quot;ready&quot;] {
	background-color: #2e7d32;
	color: #ffffff;
}

QPushButton#btn_revert[revertState=&quot;ready&quot;]:hover {
	background-color: #388e3c;
}

QPushButton#btn_revert[revertState=&quot;ready&quot;]:pressed {
	background-color: #1b5e20;
}
</string>

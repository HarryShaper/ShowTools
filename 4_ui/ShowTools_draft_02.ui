  <property name="styleSheet">
   <string notr="true">/* =========================================================
   GLOBAL
   ========================================================= */

QWidget {
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10.5pt;
    background: transparent;
}

/* Main app surfaces */
QMainWindow,
QWidget#wgShowTools,
QStackedWidget,
QStackedWidget &gt; QWidget {
    background-color: #2b2b2b;
}

/* =========================================================
   HEADER
   ========================================================= */

QFrame#headerFrame {
    background-color: #090909;
    border: none;
    border-bottom: 1px solid #1c1c1c;
}

QLabel#label_showTools {
    font-family: &quot;Segoe UI&quot;;
    font-size: 50pt;
    font-weight: 600;
    color: #ededed;
    background: transparent;
}

QLabel#label_version {
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 400;
    color: #cfcfcf;
    background: transparent;
    padding-bottom: 8px;
}

/* Header tab buttons */
QPushButton#btnMainSettings,
QPushButton#btnRenameSettings,
QPushButton#btnMainSettings:hover,
QPushButton#btnRenameSettings:hover,
QPushButton#btnMainSettings:pressed,
QPushButton#btnRenameSettings:pressed,
QPushButton#btnMainSettings:focus,
QPushButton#btnRenameSettings:focus {
    background-color: transparent;
    border: none;
    padding: 0px;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
    font-weight: 600;
    color: #ededed;
    outline: none;
}

QPushButton#btnMainSettings:checked,
QPushButton#btnRenameSettings:checked {
    color: #f0b000;
}


/* =========================================================
   TOP-LEVEL PANELS
   ========================================================= */

QFrame#frame01_instructions {
    background-color: #090909;
    border: 1px solid #1c1c1c;
    border-radius: 6px;
}

QFrame#frame02_main_settings,
QFrame#frame03_package_settings,
QFrame#frame_pipeline_profile,
QFrame#frame_project_details {
    background-color: #3a3a3a;
    border: 1px solid #323232;
    border-radius: 6px;
}

/* Make helper/container widgets inside panels transparent */
QFrame#frame01_instructions QWidget,
QFrame#frame02_main_settings QWidget,
QFrame#frame03_package_settings QWidget,
QFrame#frame_pipeline_profile QWidget,
QFrame#frame_project_details QWidget {
    background: transparent;
}

/* =========================================================
   LABELS / TITLES
   ========================================================= */

QLabel {
    color: #ededed;
    background: transparent;
}

QLabel#title_instructions,
QLabel#title_packageSettings {
    color: #ededed;
    font-size: 11pt;
    font-weight: 500;
    background: transparent;
}

/* If you later name the pipeline / project titles too, use this */
QLabel#lblSectionTitle {
    color: #ededed;
    font-size: 11pt;
    font-weight: 500;
    background: transparent;
}

/* =========================================================
   INSTRUCTIONS PANEL
   ========================================================= */

QTextBrowser#textBrowser {
    background: transparent;
    border: none;
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 9.5pt;
    padding: 0px;
}

/* =========================================================
   INPUTS
   ========================================================= */

QLineEdit,
QComboBox,
QDateEdit,
QPlainTextEdit,
QTextEdit {
    background-color: #e3e3e3;
    color: #1b1b1b;
    border: 1px solid #bdbdbd;
    border-radius: 3px;
    padding: 6px 8px;
    min-height: 24px;
}

QLineEdit:focus,
QComboBox:focus,
QDateEdit:focus,
QPlainTextEdit:focus,
QTextEdit:focus {
    border: 1px solid #f0b000;
}

QComboBox::drop-down {
    border: none;
    width: 22px;
}

/* =========================================================
   CHECKBOXES
   ========================================================= */

QCheckBox {
    spacing: 8px;
    background: transparent;
    color: #ededed;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
}

/* =========================================================
   BUTTONS
   ========================================================= */

QPushButton {
    background-color: #4a4a4a;
    color: #ededed;
    border: 1px solid #5a5a5a;
    border-radius: 4px;
    padding: 6px 10px;
}

QPushButton:hover {
    background-color: #545454;
}

QPushButton:pressed {
    background-color: #3f3f3f;
}

/* Primary export button */
QPushButton#btn_export {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    font-weight: 700;
}

QPushButton#btn_export:hover {
    background-color: #ffc533;
}

/* =========================================================
   DIVIDERS
   ========================================================= */

QFrame[frameShape=&quot;4&quot;] {
    color: #ededed;
}

QFrame[frameShape=&quot;5&quot;] {
    color: #ededed;
}

QPushButton#btn_clearSettings,
QPushButton#btn_saveSettings {
    background-color: #4a4a4a;
    color: #ededed;
    border: 1px solid #5a5a5a;
    border-radius: 4px;
    padding: 8px 14px;
    font-weight: 500;
}

/* =========================================================
  SETTINGS BUTTONS
   ========================================================= */

QPushButton#btn_clearSettings:hover,
QPushButton#btn_saveSettings:hover {
    background-color: #545454;
}</string>

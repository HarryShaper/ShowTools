  <property name="styleSheet">
   <string notr="true">/* ============================= */
/* GLOBAL TEXT */
/* ============================= */

QWidget {
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
}


/* ============================= */
/* MAIN APP SURFACES */
/* ============================= */

/* Root widget background */
QWidget#wgShowTools {
    background-color: #3a3a3a;
}

/* Stacked widget / pages = lower section background */
QStackedWidget,
QStackedWidget &gt; QWidget {
    background-color: #3a3a3a;
}

/* Lower section strip */
QFrame#lower_edge {
    background-color: #2f2f2f;
}


/* ============================= */
/* HEADER */
/* ============================= */

#headerFrame {
    background-color: #090909;
    border: none;
}

QLabel#label_showTools {
    font-weight: 600;
    font-size: 40pt;
    color: #ededed;
    background: transparent;
}

QLabel#label_version {
    font-size: 10pt;
    color: #bdbdbd;
    background: transparent;
}


/* ============================= */
/* CARD PANELS */
/* ============================= */

/* Instructions card = black */
QFrame#frame01_instructions {
    background-color: #090909;
    border-radius: 3px;
    border: none;
}

QLabel#label_resources {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10pt;
    font-weight: 600;
    background: transparent;
}

/* Main cards = darker grey than page background */
QFrame#frame_pipelineProfile,
QFrame#frame_projectDetails,
QFrame#frame_packageSettings {
    background-color: #2f2f2f;
    border: 1px solid #3a3a3a;
    border-radius: 3px;
}


QFrame#frame_targetFolder {
    background: transparent;
    border: none;
    border-bottom: 1px solid #3a3a3a;
}

/* Right column holder transparent */
QWidget#widget_columnRight {
    background: transparent;
}


/* ============================= */
/* CARD TITLES */
/* ============================= */

QLabel#title_pipelineProfile,
QLabel#title_projectDetails,
QLabel#title_packageSettings {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 12pt;
    font-weight: 700;
    background: transparent;
}

QLabel#title_targetFolder {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}

QFrame#targetFolderDivider {
    background-color: #5a5a5a;   /* softer than white */
    max-height: 2px;
    min-height: 2px;
    border: none;
}

QLabel#label_instructionsTitle {
    color: #f0b000;
    font-family: &quot;Segoe UI&quot;;
    font-size: 15pt;
    font-weight: 700;
    background: transparent;
}


/* ============================= */
/* MAIN FORM LABELS */
/* ============================= */

/* Project details body labels */
QLabel#label_projectName,
QLabel#label_shootDate,
QLabel#label_wrangler,
QLabel#label_unit {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}

/* Package settings body labels */
QLabel#label_prefix,
QLabel#label_suffix,
QLabel#label_remove,
QLabel#label_renamePackage,
QLabel#label_subfolderImages,
QLabel#label_generateYAML,
QLabel#label_notifyByEmail,
QLabel#label_flagEmptyFolders {
    color: #ffffff;
    font-weight: 600;
    font-size: 10pt;
}


/* ============================= */
/* INSTRUCTIONS PANEL */
/* ============================= */

QTextBrowser {
    background: transparent;
    border: none;
    color: #ededed;
    font-size: 9.5pt;
}

QScrollBar:vertical {
    background: #2f2f2f;
    width: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #6a6a6a;
    min-height: 20px;
    border-radius: 2px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}


/* ============================= */
/* INPUT FIELDS */
/* ============================= */

QLineEdit,
QComboBox,
QDateEdit {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-radius: 2px;
    padding: 0px 6px;
}

QLineEdit:focus,
QComboBox:focus,
QDateEdit:focus {
    border: 1px solid #f0b000;
}

QComboBox::down-arrow {
    image: url(&quot;D:/VFX/assets_and_courses/courses/Advanced_python_course/course_notes/icons/down.png&quot;);
    width: 10px;
    height: 10px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #b8b8b8;
    background-color: #cfcfcf;
}


/* ============================= */
/* CHECKBOXES */
/* ============================= */

QCheckBox {
    spacing: 6px;
    background: transparent;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
}

QCheckBox::indicator:unchecked {
    background: #dcdcdc;
    border: 1px solid #9a9a9a;
}

QCheckBox::indicator:checked {
    background: #f0b000;
    border: 1px solid #f0b000;
}


/* ============================= */
/* DIVIDER LINES */
/* ============================= */

QFrame[frameShape=&quot;4&quot;] {
    color: #6b6b6b;
}


/* ============================= */
/* BUTTONS */
/* ============================= */

/* Make all main buttons yellow */
QPushButton,
QPushButton#btn_saveSettings,
QPushButton#btn_clearSettings,
QPushButton#btn_export {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-radius: 3px;
    padding: 4px 10px;
    font-weight: 600;
}

QPushButton:hover,
QPushButton#btn_saveSettings:hover,
QPushButton#btn_clearSettings:hover,
QPushButton#btn_export:hover {
    background-color: #ffc533;
}

QPushButton:pressed,
QPushButton#btn_saveSettings:pressed,
QPushButton#btn_clearSettings:pressed,
QPushButton#btn_export:pressed {
    background-color: #d89c00;
}

/* Top tabs */
QPushButton#btn_mainSettings,
QPushButton#btn_renameSettings {
    background: transparent;
    border: none;
    font-weight: 600;
    font-size: 11pt;
    color: #ededed;
}

QPushButton#btn_mainSettings:checked,
QPushButton#btn_renameSettings:checked {
    color: #f0b000;
}

/* Browse icon buttons */
QPushButton#btn_browseConfig {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-radius: 2px;
    padding: 0px;
    min-width: 28px;
    max-width: 28px;
    min-height: 28px;
    max-height: 28px;
}

QPushButton#btn_browseTargetFolder {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    border-left: 1px solid #b8b8b8;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-top-left-radius: 0px;
    border-bottom-left-radius: 0px;
    padding: 0px;
    min-width: 21px;
    max-width: 21px;
    min-height: 21px;
    max-height: 21px;
}

QPushButton#btn_browseConfig:hover,
QPushButton#btn_browseTargetFolder:hover {
    background-color: #ffc533;
}

QPushButton#btn_browseConfig:pressed,
QPushButton#btn_browseTargetFolder:pressed {
    background-color: #d89c00;
}

/* Instruction icon buttons */
QPushButton#btn_youtube,
QPushButton#btn_website,
QPushButton#btn_gmail,
QPushButton#btn_github,
QPushButton#btn_linkedin {
    background: transparent;
    border: none;
    padding: 4px;
}

QPushButton#btn_youtube:hover,
QPushButton#btn_website:hover,
QPushButton#btn_gmail:hover,
QPushButton#btn_github:hover,
QPushButton#btn_linkedin:hover {
    background-color: #2f2f2f;
    border-radius: 3px;
}


/* ============================= */
/* COMBO BOXES */
/* ============================= */

QComboBox {
    background-color: #dcdcdc;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-radius: 2px;
    padding: 1px 6px;
    min-height: 24px;
}

QComboBox:focus {
    border: 1px solid #f0b000;
}

/* Right-side drop area */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #bcbcbc;
    background-color: #d0d0d0;
}

/* Visible arrow */
QComboBox::down-arrow {
    width: 10px;
    height: 10px;
}

/* Popup list */
QComboBox QAbstractItemView {
    background-color: #2f2f2f;
    color: #ededed;
    border: 1px solid #4a4a4a;
    selection-background-color: #f0b000;
    selection-color: #1b1b1b;
    outline: none;
}


/* ============================= */
/* DATE EDIT */
/* ============================= */

QDateEdit {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #b8b8b8;
    border-radius: 2px;
    padding: 1px 6px;
    min-height: 24px;
}

QDateEdit:focus {
    border: 1px solid #f0b000;
}

QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #b8b8b8;
    background-color: #cccccc;
}

QDateEdit::down-arrow {
    image: url(&quot;D:/VFX/assets_and_courses/courses/Advanced_python_course/course_notes/icons/calendar.png&quot;);
    width: 12px;
    height: 12px;
}


/* ============================= */
/* CALENDAR POPUP */
/* ============================= */

QCalendarWidget QWidget {
    background-color: #2f2f2f;
    color: #ededed;
}

QCalendarWidget QToolButton {
    background-color: #2f2f2f;
    color: #f0b000;
    border: none;
    font-weight: 600;
}

QCalendarWidget QToolButton:hover {
    background-color: #3a3a3a;
}

QCalendarWidget QMenu {
    background-color: #2f2f2f;
    color: #ededed;
    border: 1px solid #4a4a4a;
}

QCalendarWidget QSpinBox {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #b8b8b8;
    border-radius: 2px;
}

QCalendarWidget QAbstractItemView:enabled {
    background-color: #2f2f2f;
    color: #ededed;
    selection-background-color: #f0b000;
    selection-color: #1b1b1b;
    outline: none;
}

QCalendarWidget QAbstractItemView:disabled {
    color: #777777;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: #2f2f2f;
    border-bottom: 1px solid #3a3a3a;
}

QCalendarWidget QToolButton {
    padding-right: 12px;
}

QLineEdit#input_targetFolder {
    background-color: #d6d6d6;
    color: #1b1b1b;
    border: 1px solid #bcbcbc;
    border-right: none;
    border-top-left-radius: 2px;
    border-bottom-left-radius: 2px;
    border-top-right-radius: 0px;
    border-bottom-right-radius: 0px;
    padding: 0px 6px;
}

QLineEdit#input_targetFolder[pathState=&quot;missing&quot;] {
    border: 2px solid #d96c6c;
}

QLineEdit#input_targetFolder[pathState=&quot;valid&quot;] {
    border: 2px solid #5fcf8f;
}

QLineEdit:disabled {
    background-color: #5a5a5a;
    color: #9a9a9a;
    border: 1px solid #4a4a4a;
}

QComboBox:disabled,
QDateEdit:disabled {
    background-color: #5a5a5a;
    color: #9a9a9a;
    border: 1px solid #4a4a4a;
}</string>

  <property name="styleSheet">
   <string notr="true">/* ---------- Global text styling (NO background here) ---------- */
QWidget {
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 10.5pt;
}

QLabel#label_version {
    padding-bottom: 8px;
}

QTextBrowser#txtInstructions {
    background: transparent;
    border: none;
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 9.5pt;     /* try 9pt if still big */
}

QTextBrowser#txtInstructions h3 {
    font-size: 11pt;
    font-weight: 700;
    margin: 0px 0px 6px 0px;
}

QTextBrowser#txtInstructions h4 {
    font-size: 10pt;
    font-weight: 600;
    margin: 10px 0px 4px 0px;
}

QTextBrowser#txtInstructions p {
    margin: 0px 0px 6px 0px;
}

QFrame#frameInstructions {
    background-color: #090909;  /* same deep black */
    border-radius: 6px;
    border: 1px solid #1c1c1c;
}

/* Title */
QLabel#labelInstructionsTitle {
    color: #ededed;
    font-weight: 700;
    font-size: 12pt;
    background: transparent;
}

/* Body text */
QTextEdit#txtInstructions,
QPlainTextEdit#txtInstructions {
    background: transparent;
    border: none;
    color: #ededed;
    font-size: 10.5pt;
    padding: 0px;
}

QTextBrowser#txtInstructions {
    background: transparent;
    border: none;
    color: #ededed;
    font-family: &quot;Segoe UI&quot;;
    font-size: 9.5pt;      /* reduce from 10.5 */
}

/* ---------- Only paint the app background on main surfaces ---------- */
QMainWindow,
QWidget#wgShowTools,
QStackedWidget,
QStackedWidget &gt; QWidget {
    background-color: #2b2b2b;
}

/* ---------- Header ---------- */
#headerFrame {
    background-color: #090909;
    border-bottom: 1px solid #3c3c3c;
}

QLabel#label_showTools {
    font-family: &quot;Segoe UI&quot;;
    font-weight: 600;      /* Semibold */
    font-size: 50pt;       /* adjust */
    color: #eaeaea;
    background: transparent;
}

QLabel#label_version {
    font-family: &quot;Segoe UI&quot;;
    font-weight: 400;
    font-size: 10pt;
    color: #cfcfcf;
    background: transparent;
}

QFrame[frameShape=&quot;5&quot;] { /* VLine */
    color: #9a9a9a;
}

/* ---------- Section panels ---------- */
QFrame#frame_pipelineProfile,
QFrame#frame_projectDetails,
QFrame#frame_packageSettings,
QFrame#instructionsFrame {
    background-color: #3a3a3a;
    border-radius: 6px;
}

/* IMPORTANT: make “layout helper” widgets transparent inside panels */
QFrame#frame_pipelineProfile QWidget,
QFrame#frame_projectDetails QWidget,
QFrame#frame_packageSettings QWidget,
QFrame#instructionsFrame QWidget {
    background: transparent;
}

/* ---------- Labels ---------- */
QLabel {
    background: transparent;
    color: #eaeaea;
}

/* ---------- Inputs ---------- */
QLineEdit, QComboBox, QDateEdit, QPlainTextEdit, QTextEdit {
    background-color: #d8d8d8;
    color: #1b1b1b;
    border: 1px solid #bdbdbd;
    border-radius: 4px;
    padding: 6px;
}

QFrame#frameTabDivider {
    color: #ffffff;          /* for VLine/HLine drawing */
    background: transparent;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus, QPlainTextEdit:focus, QTextEdit:focus {
    border: 1px solid #f0b000;
}

/* Combo dropdown */
QComboBox::drop-down {
    border: none;
    width: 22px;
}

/* ---------- Checkboxes ---------- */
QCheckBox {
    spacing: 8px;
    background: transparent;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
}

/* ---------- Buttons ---------- */
QPushButton {
    background-color: #4a4a4a;
    border: 1px solid #5a5a5a;
    border-radius: 4px;
    padding: 6px 10px;
}

QPushButton:hover {
    background-color: #545454;
}

QPushButton:pressed {
    background-color: #3f3f3f;
}

/* Primary action */
QPushButton#btnExport {
    background-color: #f0b000;
    color: #1b1b1b;
    border: none;
    font-weight: 700;
}

QPushButton#btnExporty:hover {
    background-color: #ffc533;
}

/* ---------- Fake-tab header buttons ---------- */
QPushButton#btnMainSettings,
QPushButton#btnRenameSettings {
    background: transparent;
    border: none;
    padding: 0px 0px;
    font-weight: 600;
    font-size: 11pt;
    color: #ffffff;
}

QPushButton#btnMainSettings:checked,
QPushButton#btnRenameSettings:checked {
    color: #f0b000;
}

/* ---------- Divider lines (HLine frames) ---------- */
QFrame[frameShape=&quot;4&quot;] { /* HLine */
    color: #ffffff;
}</string>
